# ── PSADT Agentic AI — Environment Configuration ──────────────────────────
# Copy this file to .env and fill in your values.

# ── REQUIRED ──────────────────────────────────────────────────────────────

# Groq API key — get one at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ── OPTIONAL ──────────────────────────────────────────────────────────────

# Groq model to use for all agents
# Options: llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Path to your PSADT template directory
# Must contain: AppDeployToolkit/ folder with AppDeployToolkitMain.ps1
PSADT_TEMPLATE_PATH=C:\PSAppDeployToolkit\Toolkit

# PSADT version string (informational — auto-detected from template)
PSADT_VERSION=3.10.2

# Test mode: "host" runs on this machine, "sandbox" uses Windows Sandbox
# WARNING: "host" will actually install/uninstall software on this PC
TEST_MODE=host

# Human-in-the-Loop bypass
# Set to "true" ONLY for automated pipelines — NOT recommended for production
# Default: false (HITL is ENABLED and gates require manual approval)
HITL_BYPASS=false

# MCP transport (leave as stdio unless you need HTTP)
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=8765
